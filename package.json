{
  "name": "dira-api",
  "version": "1.0.0",
  "description": "Fastify Backend API for the Dira Weather Sensing DePIN platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node src/db/migrate.ts",
    "test:midnight": "tsx src/test_midnight_jobs.ts"
  },
  "keywords": [
    "fastify",
    "typescript",
    "depin",
    "dira",
    "api"
  ],
