# Environment
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql://dira_user:dira_password@localhost:5432/dira_db?schema=public

# Redis (used for BullMQ background job queues)
REDIS_URL=redis://localhost:6379

# Authentication JWT Secret
JWT_SECRET=replace_with_a_secure_random_key_of_at_least_32_characters

# Feature Flags
DIRA_CIRCLE_ACTIVE=true
VOUCHERS_ACTIVE=false

# Hedera Configuration
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=your_hedera_operator_account_id
HEDERA_OPERATOR_KEY=your_hedera_operator_private_key
DIRA_HCS_TOPIC_ID=your_hedera_consensus_topic_id
DIRA_HTS_TOKEN_ID=your_hedera_token_service_token_id

# Pretium Configuration
PRETIUM_BASE_URL=https://sandbox-api.pretium.io
PRETIUM_API_KEY=your_pretium_sandbox_api_key
PRETIUM_WEBHOOK_SECRET=your_pretium_webhook_signature_secret

# AI Crop Verification
GEMINI_API_KEY=your_gemini_api_key


