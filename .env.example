# Environment
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql://dira_user:dira_password@localhost:5432/dira_db?schema=public

# Redis (used for BullMQ background job queues)
REDIS_URL=redis://localhost:6379

# Authentication JWT Secret
JWT_SECRET=replace_with_a_secure_random_key_of_at_least_32_characters

# Safaricom Daraja B2C M-Pesa Gate
# Set to true to activate production M-Pesa payouts
DARAJA_PRODUCTION_ACTIVE=false
DIRA_CIRCLE_ACTIVE=true

# XION Configuration
XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
XION_MNEMONIC="your twelve word xion account mnemonic"
XION_CONTRACT_ADDRESS="xion1..."

# zkVerify Configuration (Proof Verification Layer)
# Volta testnet during development (API URL: https://volta-rpc.zkverify.io)
# Switch to mainnet before pilot
ZKVERIFY_API_URL=https://volta-rpc.zkverify.io
ZKVERIFY_VK_ID="your_verification_key_id"
ZKVERIFY_SEED_PHRASE="your twelve word Substrate account seed phrase"

