# Environment
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql://dira_user:dira_password@localhost:5432/dira_db?schema=public

# Redis (used for BullMQ background job queues)
REDIS_URL=redis://localhost:6379

# Authentication JWT Secret
JWT_SECRET=replace_with_a_secure_random_key_of_at_least_32_characters

# Safaricom Daraja B2C M-Pesa Gate
# Set to true to activate production M-Pesa payouts
DARAJA_PRODUCTION_ACTIVE=false
